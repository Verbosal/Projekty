# Main variables
PORT=1337           # Port at which you'd like to locally host, like localhost:1337

# Operations at the start of every runtime
# Whether to create something
CREATE_USERS=true   # Create example users, defined in ./templates/users.json
CREATE_POSTS=true   # Create example posts, defined in ./templates/posts.json
CREATE_ADMINS=true  # Create admin account(s), defined in ./templates/admins.json

# Whether to clear
CLEAR_DB=true                   # Clear the entire database at the start of every runtime, basically the equivalent of checking the rest of the

CLEAR_USERS=true                # Clear users
CLEAR_POSTS=true                # Clear posts
CLEAR_ADMINS_PRIVILEGES=true    # Clear all admin privileges

# ----------------------------------------------------------
# Do not touch! These are necessary for encrypting passwords
SECRET=\"$(cat /dev/random | tr -cd "[:graph:]" | head -c64)\"
PEPPER=\"$(cat /dev/random | tr -cd "[:xdigit:]" | head -c64)\"n