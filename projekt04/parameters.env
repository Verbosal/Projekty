# Customizable
PORT=1337 # Port at which you host, like localhost:1337
CLEAR_DB=true # Whether to clear the database every runtime
POPULATE_DB=true # Whether to add a few example users, defined in ./database/populate.js
CREATE_ADMINS=true # Whether to create admin accounts described in ./database/admins.json

# Do not touch!
SECRET=\"$(cat /dev/random | tr -cd "[:graph:]" | head -c64)\"
PEPPER=\"$(cat /dev/random | tr -cd "[:xdigit:]" | head -c64)\"n