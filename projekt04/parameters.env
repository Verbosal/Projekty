# Customizable variables
PORT=1337           # Port at which you'd like to locally host, like localhost:1337
CLEAR_DB=true       # Whether to clear the database at the start of every runtime

CREATE_USERS=true   # Whether to add example users, defined in ./templates/users.json
CREATE_POSTS=true   # Whether to add example posts, defined in ./templates/posts.json
CREATE_ADMINS=true  # Whether to create admin accounts defined in ./templates/admins.json

# Do not touch! These are necessary for encrypting passwords
SECRET=\"$(cat /dev/random | tr -cd "[:graph:]" | head -c64)\"
PEPPER=\"$(cat /dev/random | tr -cd "[:xdigit:]" | head -c64)\"n